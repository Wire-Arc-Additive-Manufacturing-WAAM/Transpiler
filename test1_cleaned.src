CONTINUE
$OUT[1] = FALSE
WAIT SEC 0.5

;===========
; BEGIN WAAM PROCESS
;===========

; Auto prusa origin applied: x=-0.000, y=25.000
; ;LAYER_CHANGE
; ;Z:2
LIN {X 0.000, Y 0.000, Z 0.000, A 129.7, B -46.5, C 162.4} C_DIS
CONTINUE
$OUT[1] = TRUE
LIN {X 0.000, Y 50.000, Z 0.000, A 129.7, B -46.5, C 162.4} C_DIS
CONTINUE
