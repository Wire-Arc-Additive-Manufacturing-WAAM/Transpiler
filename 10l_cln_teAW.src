$OUT[1] = FALSE
WAIT SEC 0.200
; Lift Z by 10.0mm to avoid scratching welded bead
LIN_REL {Z 10.0}
; Stabilization delay - ensures travel motion completes before Z lowers
WAIT SEC 5.0
;Waiting for TEMP_VAR to go high indicating temperature reached before next layer
WAIT SEC 30
WAIT FOR TEMP_VAR
WAIT SEC 30
; Lower Z back to weld height
LIN_REL {Z -10.0}
; ;LAYER_CHANGE
; Reset TEMP_VAR at the start of this layer
TEMP_VAR = FALSE
; Layer index: 5
OFFSET_POS = {X 95.500, Y 0.000, Z 6.000, A 0, B 0, C 0}
TARGET_POS = TAUGHT_START
TARGET_POS.X = TAUGHT_START.X + OFFSET_POS.X
TARGET_POS.Y = TAUGHT_START.Y + OFFSET_POS.Y
TARGET_POS.Z = TAUGHT_START.Z + OFFSET_POS.Z
TARGET_POS.A = TAUGHT_START.A
TARGET_POS.B = TAUGHT_START.B
TARGET_POS.C = TAUGHT_START.C
LIN TARGET_POS C_DIS
$OUT[1] = TRUE
WAIT SEC 0.200
