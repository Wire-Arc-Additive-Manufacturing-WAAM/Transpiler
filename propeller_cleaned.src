TARGET_POS.C = TAUGHT_START.C
LIN TARGET_POS C_DIS
$OUT[1] = FALSE
WAIT SEC 0.200
; Lift Z by 10.0mm to avoid scratching welded bead
LIN_REL {Z 10.0}
; Stabilization delay - ensures travel motion completes before Z lowers
WAIT SEC 5.0
;Waiting for TEMP_VAR to go high indicating temperature reached before next layer
WAIT SEC 30
WAIT FOR TEMP_VAR
WAIT SEC 30
; Lower Z back to weld height
LIN_REL {Z -10.0}

;===========
; WAAM PROCESS COMPLETE
;===========

$VEL.CP = 0.0099
LIN_REL {Z 30}
WAIT SEC 0
$OV_PRO = 10
PTP HOME

END
