WAIT SEC 10.00
; ;LAYER_CHANGE
; ;Z:4
LIN {X 0.000, Y 50.000, Z 2.000, A 129.7, B -46.5, C 162.4} C_DIS
CONTINUE
$OUT[1] = TRUE
LIN {X 0.000, Y 0.000, Z 2.000, A 129.7, B -46.5, C 162.4} C_DIS
CONTINUE
$OUT[1] = FALSE
WAIT SEC 10.00
; ;LAYER_CHANGE
; ;Z:6
LIN {X 0.000, Y 0.000, Z 4.000, A 129.7, B -46.5, C 162.4} C_DIS
CONTINUE
$OUT[1] = TRUE
LIN {X 0.000, Y 50.000, Z 4.000, A 129.7, B -46.5, C 162.4} C_DIS
CONTINUE
$OUT[1] = FALSE
