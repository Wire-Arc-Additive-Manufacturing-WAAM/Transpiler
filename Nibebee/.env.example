# --- Database (PostgreSQL) ---
# Local (docker-compose in this repo maps host 5433 -> container 5432)
DATABASE_URL=postgresql://nibebee:nibebee@localhost:5433/nibebee

# --- Redis (rate limiting / Socket.io adapter in production) ---
REDIS_URL=redis://localhost:6379

# --- NestJS API ---
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
JWT_ACCESS_SECRET=replace-with-long-random-string-min-32-chars
JWT_REFRESH_PEPPER=optional-second-secret-for-extra-hardening

# --- Next.js (copy to frontend/.env.local) ---
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (Auth: OTP + OAuth) ---
# In Supabase dashboard: Project Settings -> API -> Project URL & anon/service keys
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- Africa's Talking (SMS OTP, route alerts, broadcasts) ---
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=NIBEBEE

# --- Cloudinary (lorry photos, dispute evidence) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Flutterwave (subscriptions, escrow collections) ---
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_ENCRYPTION_KEY=
FLW_WEBHOOK_SECRET=

# --- PayPal Business (platform net revenue payouts) ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BUSINESS_EMAIL=owner@your-domain.com

# --- Resend (transactional email + contract PDF delivery) ---
RESEND_API_KEY=
EMAIL_FROM=Nibebee <no-reply@your-domain.com>

# --- KYC document encryption (AES-256-GCM; 32-byte key as hex) ---
KYC_ENCRYPTION_KEY_HEX=

# --- Optional: first admin seed ---
ADMIN_SEED_EMAIL=admin@nibebee.local
ADMIN_SEED_PASSWORD=ChangeMe!Admin123
